generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum MovementType {
  SUPPLIER_INCOME
  PRODUCTION_INCOME
  ASSEMBLY_WRITE_OFF
  ASSEMBLY_INCOME
  ADJUSTMENT_INCOME
  ADJUSTMENT_WRITE_OFF
}

enum LocationType {
  WAREHOUSE
  PRODUCTION
  WIP
  SCRAP
}

enum WorkerRole {
  WORKER
  WAREHOUSE
  DIRECTOR
}

enum OrderStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BomStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum RoutingStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum InventoryOperationType {
  SUPPLIER_RECEIPT
  ASSEMBLY
  ORDER_COMPLETION
  ADJUSTMENT
}

// --- Code Generation ---

model CodeCounter {
  key   String @id // MATERIAL, BLANK, PRODUCT
  value Int    @default(0)

  @@map("code_counters")
}

// --- Auth & Users ---

// Роли пользователей (гибкая таблица)
model Role {
  id    String @id // "admin", "director", "warehouse"
  name  String // "Администратор", "Директор", "Кладовщик"
  users User[]

  @@map("roles")
}

// Пользователи (веб-доступ: email + пароль)
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  isActive     Boolean  @default(true) @map("is_active")
  roleId       String   @map("role_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role   Role    @relation(fields: [roleId], references: [id])
  worker Worker?

  // Audit trail
  createdItems         Item[]            @relation("ItemCreator")
  updatedItems         Item[]            @relation("ItemUpdater")
  createdStockMovements StockMovement[]  @relation("MovementCreator")
  createdProductionOrders ProductionOrder[] @relation("OrderCreatorUser")
  orderStatusChanges   ProductionOrderStatusHistory[] @relation("StatusChanger")
  inventoryOperations  InventoryOperation[]           @relation("OperationCreator")
  createdBoms          Bom[]                          @relation("BomCreator")

  @@map("users")
}

// Конфигурация приложения (настройки клиента)
model AppConfig {
  key         String @id
  value       String
  description String?

  @@map("app_config")
}

// --- Locations ---

model Location {
  id   String       @id // стабильный системный код (MAIN, RAW, FG)
  name String       // отображаемое имя
  type LocationType

  fromMovements StockMovement[] @relation("FromLocation")
  toMovements   StockMovement[] @relation("ToLocation")
  balances      StockBalance[]

  @@map("locations")
}

// Бизнес-команда, объединяющая несколько движений
model InventoryOperation {
  id           String                  @id @default(cuid())
  operationKey String                  @unique @map("operation_key")
  type         InventoryOperationType
  createdById  String?                 @map("created_by_id")
  createdAt    DateTime                @default(now()) @map("created_at")

  createdBy User?           @relation("OperationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  movements StockMovement[]

  @@index([type, createdAt])
  @@map("inventory_operations")
}

// Кэш остатков (read model, пересчитывается из StockMovement)
model StockBalance {
  itemId     String   @map("item_id")
  locationId String   @map("location_id")
  quantity   Decimal  @db.Decimal(10, 4)
  updatedAt  DateTime @updatedAt @map("updated_at")

  item     Item     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@id([itemId, locationId])
  @@index([locationId])
  @@map("stock_balances")
}

// --- Nomenclature & Catalog ---

// Типы номенклатуры (гибкая таблица вместо enum)
model ItemType {
  id    String @id // "material", "blank", "product"
  name  String // "Сырьё", "Заготовка", "Изделие"
  order Int    @default(0) // порядок сортировки
  color String @default("gray") // цвет для бейджа (amber, orange, blue, purple, emerald)
  items Item[]

  @@map("item_types")
}

// Единицы измерения
model Unit {
  id    String @id // "kg", "pcs", "m"
  name  String // "кг", "шт", "м"
  items Item[]

  @@map("units")
}

// Категории для группировки
model Category {
  id    String @id
  name  String
  image String?
  items Item[]

  @@map("categories")
}

// Позиция номенклатуры
model Item {
  id           String  @id
  code         String  @unique
  name         String
  typeId       String  @map("type_id")
  unitId       String  @map("unit_id")
  categoryId   String? @map("category_id")
  description  String?
  images       String[] // массив URL фото
  pricePerUnit Decimal? @map("price_per_unit") @db.Decimal(10, 2)

  type     ItemType  @relation(fields: [typeId], references: [id])
  unit     Unit      @relation(fields: [unitId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  // BOM связи (runtime)
  childOf  BomEntry[] @relation("BomChild")
  parentOf BomEntry[] @relation("BomParent")

  // BOM версии
  boms          Bom[]     @relation("BomItem")
  bomComponents BomLine[] @relation("BomLineComponent")

  // Маршруты
  routings Routing[]

  // Складские движения и остатки
  stockMovements StockMovement[]
  stockBalances  StockBalance[]

  // Производственные заказы
  productionOrders     ProductionOrder[]
  productionOrderItems ProductionOrderItem[]

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at") // soft delete
  createdById String?   @map("created_by_id")
  updatedById String?   @map("updated_by_id")

  createdByUser User? @relation("ItemCreator", fields: [createdById], references: [id])
  updatedByUser User? @relation("ItemUpdater", fields: [updatedById], references: [id])

  @@index([deletedAt])
  @@map("items")
}

// Связь "из чего состоит" (Bill of Materials)
model BomEntry {
  id       String @id @default(cuid())
  parentId String @map("parent_id")
  childId  String @map("child_id")
  quantity Decimal @db.Decimal(10, 4) // сколько единиц child нужно на 1 единицу parent

  parent Item @relation("BomParent", fields: [parentId], references: [id], onDelete: Restrict)
  child  Item @relation("BomChild", fields: [childId], references: [id], onDelete: Restrict)

  @@unique([parentId, childId])
  @@map("bom_entries")
}

// Версия BOM
model Bom {
  id            String    @id @default(cuid())
  itemId        String    @map("item_id")
  version       Int
  status        BomStatus @default(DRAFT)
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  createdById   String?   @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  item      Item      @relation("BomItem", fields: [itemId], references: [id], onDelete: Restrict)
  createdBy User?     @relation("BomCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lines     BomLine[]
  orders    ProductionOrder[]

  @@unique([itemId, version])
  @@index([itemId, status])
  @@map("boms")
}

// Строка версионного BOM
model BomLine {
  id              String   @id @default(cuid())
  bomId           String   @map("bom_id")
  lineNo          Int      @map("line_no")
  componentItemId String   @map("component_item_id")
  quantity        Decimal  @db.Decimal(10, 4)
  scrapFactor     Decimal? @db.Decimal(8, 4) @map("scrap_factor")
  note            String?

  bom           Bom  @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentItem Item @relation("BomLineComponent", fields: [componentItemId], references: [id], onDelete: Restrict)

  @@unique([bomId, lineNo])
  @@index([componentItemId])
  @@map("bom_lines")
}

// Рабочие (авторизация по PIN на терминале)
model Worker {
  id        String      @id @default(cuid())
  name      String
  pin       String      @unique
  role      WorkerRole  @default(WORKER)
  active    Boolean     @default(true)
  userId    String?     @unique @map("user_id")
  createdAt DateTime    @default(now()) @map("created_at")

  user           User?             @relation(fields: [userId], references: [id])
  productionLogs ProductionLog[]
  stockMovements StockMovement[]
  createdOrders  ProductionOrder[] @relation("OrderCreator")

  @@map("workers")
}

// Журнал выработки
model ProductionLog {
  id           String   @id @default(cuid())
  workerId     String   @map("worker_id")
  itemId       String   @map("item_id")
  itemName     String   @map("item_name")
  quantity     Int
  pricePerUnit Decimal  @map("price_per_unit") @db.Decimal(10, 2)
  total        Decimal  @db.Decimal(10, 2)
  orderId      String?  @map("order_id")
  createdAt    DateTime @default(now()) @map("created_at")

  worker Worker           @relation(fields: [workerId], references: [id])
  order  ProductionOrder? @relation(fields: [orderId], references: [id])

  @@index([workerId, createdAt])
  @@index([orderId, createdAt])
  @@map("production_logs")
}

// Группы производственных процессов
model ProcessGroup {
  id    String @id
  name  String
  order Int   @default(0)

  processes Process[]

  @@map("process_groups")
}

// Производственные процессы (справочник операций)
model Process {
  id      String @id
  name    String
  groupId String @map("group_id")
  order   Int    @default(0)

  group        ProcessGroup @relation(fields: [groupId], references: [id])
  routingSteps RoutingStep[]

  @@map("processes")
}

// Маршрут производства
model Routing {
  id        String        @id @default(cuid())
  itemId    String        @map("item_id")
  version   Int
  status    RoutingStatus @default(DRAFT)
  createdAt DateTime      @default(now()) @map("created_at")

  item  Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  steps RoutingStep[]

  @@unique([itemId, version])
  @@index([itemId, status])
  @@map("routings")
}

// Шаг маршрута
model RoutingStep {
  id           String   @id @default(cuid())
  routingId    String   @map("routing_id")
  stepNo       Int      @map("step_no")
  processId    String   @map("process_id")
  normTimeMin  Decimal? @db.Decimal(10, 2) @map("norm_time_min")
  setupTimeMin Decimal? @db.Decimal(10, 2) @map("setup_time_min")
  note         String?

  routing Routing @relation(fields: [routingId], references: [id], onDelete: Cascade)
  process Process @relation(fields: [processId], references: [id], onDelete: Restrict)

  @@unique([routingId, stepNo])
  @@index([processId])
  @@map("routing_steps")
}

// Складские движения
model StockMovement {
  id             String   @id @default(cuid())
  type           MovementType
  itemId         String   @map("item_id")
  quantity       Decimal  @db.Decimal(10, 4)
  workerId       String?  @map("worker_id")
  orderId        String?  @map("order_id")
  operationId    String?  @map("operation_id")
  fromLocationId String?  @map("from_location_id")
  toLocationId   String?  @map("to_location_id")
  comment        String?
  createdById    String?  @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  item          Item                @relation(fields: [itemId], references: [id], onDelete: Restrict)
  worker        Worker?             @relation(fields: [workerId], references: [id])
  order         ProductionOrder?    @relation(fields: [orderId], references: [id])
  operation     InventoryOperation? @relation(fields: [operationId], references: [id], onDelete: SetNull)
  fromLocation  Location?           @relation("FromLocation", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation    Location?           @relation("ToLocation", fields: [toLocationId], references: [id], onDelete: Restrict)
  createdByUser User?               @relation("MovementCreator", fields: [createdById], references: [id])

  @@index([itemId, createdAt])
  @@index([orderId, createdAt])
  @@index([fromLocationId, createdAt])
  @@index([toLocationId, createdAt])
  @@map("stock_movements")
}

// Производственные заказы
model ProductionOrder {
  id                String      @id @default(cuid())
  status            OrderStatus @default(PLANNED)
  itemId            String      @map("item_id")
  itemName          String      @map("item_name")
  quantityPlanned   Int         @map("quantity_planned")
  quantityCompleted Int         @default(0) @map("quantity_completed")
  bomId             String?     @map("bom_id") // версия BOM, по которой создан заказ
  createdBy         String      @map("created_by")
  createdByUserId   String?     @map("created_by_user_id")
  createdAt         DateTime    @default(now()) @map("created_at")
  startedAt         DateTime?   @map("started_at")
  completedAt       DateTime?   @map("completed_at")

  item          Item    @relation(fields: [itemId], references: [id], onDelete: Restrict)
  bom           Bom?    @relation(fields: [bomId], references: [id], onDelete: SetNull)
  creator       Worker  @relation("OrderCreator", fields: [createdBy], references: [id])
  createdByUser User?   @relation("OrderCreatorUser", fields: [createdByUserId], references: [id])

  snapshotItems  ProductionOrderItem[]
  productionLogs ProductionLog[]
  stockMovements StockMovement[]
  statusHistory  ProductionOrderStatusHistory[]

  @@index([status, createdAt])
  @@map("production_orders")
}

// История статусов заказа
model ProductionOrderStatusHistory {
  id          String       @id @default(cuid())
  orderId     String       @map("order_id")
  fromStatus  OrderStatus? @map("from_status")
  toStatus    OrderStatus  @map("to_status")
  changedById String?      @map("changed_by_id")
  comment     String?
  changedAt   DateTime     @default(now()) @map("changed_at")

  order     ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Restrict)
  changedBy User?           @relation("StatusChanger", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([orderId, changedAt])
  @@map("production_order_status_history")
}

// Snapshot состава заказа (BOM на момент создания)
model ProductionOrderItem {
  id       String  @id @default(cuid())
  orderId  String  @map("order_id")
  itemId   String  @map("item_id")
  itemName String  @map("item_name")
  quantity Decimal @db.Decimal(10, 4)

  order ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item  Item            @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([orderId, itemId])
  @@map("production_order_items")
}
